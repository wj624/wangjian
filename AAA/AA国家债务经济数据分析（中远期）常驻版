     tooltip="剪刀差为正时，只有实际利率低于此值才判定为真宽松扩张，否则视为虚假繁荣", group=group_core)
th_inversion    = input.float(-0.3, "衰退确认: 倒挂深度阈值(过去6个月最低利差)",
     tooltip="只有过去6个月内出现深度倒挂（低于此值）后的修复，才确认为衰退启动", group=group_core)
th_stagflation  = input.int(3, "滞胀预警触发分数(满分4分)",
     tooltip="PPI高位+传导不畅+M2下行+曲线倒挂，各1分，达到此分数触发滞胀预警", group=group_core,
     minval=1, maxval=4)
m1_mom_ma_len   = input.int(3, "M1环比平滑周期(月)",
     tooltip="M1月度环比的SMA平滑，用于识别货币活化拐点，领先M1同比约6个月", group=group_core,
     minval=1)
dxy_symbol    = input.string("TVC:DXY",   "全球流动性指标",   group=group_core)
us_10y_symbol = input.string("TVC:US10Y", "美国10年期国债",   group=group_core)

// ── 字体设置 ──
grp_font = "字体设置"
font_size = input.string("small", "全局字体大小", options=["tiny", "small", "normal"], group=grp_font)
text_sz   = font_size == "tiny" ? size.tiny : font_size == "small" ? size.small : size.normal


// ==========================================
// 4. 4国数据抓取（V26 走势图所需）
// ==========================================
us_d = f_get_macro("FRED:GFDEGDQ188S")
us_y = f_get_macro("TVC:US10Y")
us_g = f_get_macro("ECONOMICS:USGDPYY")

cn_d = f_get_macro("ECONOMICS:CNGDG")
cn_y = f_get_macro("TVC:CN10Y")
cn_g = f_get_macro("ECONOMICS:CNGDPYY")

jp_d = f_get_macro("ECONOMICS:JPGDG")
jp_y = f_get_macro("TVC:JP10Y")
jp_g = f_get_macro("ECONOMICS:JPGDPYY")

eu_d = f_get_macro("ECONOMICS:EUGDG")
eu_y = f_get_macro("TVC:DE10Y")
eu_g = f_get_macro("ECONOMICS:EUGDPYY")

// 4国Dalio指标
f_calc_val(_mode, _debt, _yield, _gdp) =>
    _mode == "模式A：名义GDP增长率减去10年国债收益率，越高越好" ? (_gdp - _yield) : ((_debt / 100) * _yield)

res_us = f_calc_val(calc_mode, us_d, us_y, us_g)
res_cn = f_calc_val(calc_mode, cn_d, cn_y, cn_g)
res_jp = f_calc_val(calc_mode, jp_d, jp_y, jp_g)
res_eu = f_calc_val(calc_mode, eu_d, eu_y, eu_g)

// 4国总计利息压力 - 保持原始公式
tp_us = us_d * ((us_d / 100) * us_y)
tp_cn = cn_d * ((cn_d / 100) * cn_y)
tp_jp = jp_d * ((jp_d / 100) * jp_y)
tp_eu = eu_d * ((eu_d / 100) * eu_y)

// 4国严重度 & 趋势
is_mode_A = calc_mode == "模式A：名义GDP增长率减去10年国债收益率，越高越好"

sev_us = f_severity(calc_mode, res_us, us_d)
sev_cn = f_severity(calc_mode, res_cn, cn_d)
sev_jp = f_severity(calc_mode, res_jp, jp_d)
sev_eu = f_severity(calc_mode, res_eu, eu_d)

prev_us = nz(res_us[20], res_us)
prev_cn = nz(res_cn[20], res_cn)
prev_jp = nz(res_jp[20], res_jp)
prev_eu = nz(res_eu[20], res_eu)

trend_us = is_mode_A ? (res_us > prev_us + 0.1 ? "↑ 改善" : res_us < prev_us - 0.1 ? "↓ 恶化" : "→ 持平") : (res_us < prev_us - 0.1 ? "↑ 改善" : res_us > prev_us + 0.1 ? "↓ 恶化" : "→ 持平")
trend_cn = is_mode_A ? (res_cn > prev_cn + 0.1 ? "↑ 改善" : res_cn < prev_cn - 0.1 ? "↓ 恶化" : "→ 持平") : (res_cn < prev_cn - 0.1 ? "↑ 改善" : res_cn > prev_cn + 0.1 ? "↓ 恶化" : "→ 持平")
trend_jp = is_mode_A ? (res_jp > prev_jp + 0.1 ? "↑ 改善" : res_jp < prev_jp - 0.1 ? "↓ 恶化" : "→ 持平") : (res_jp < prev_jp - 0.1 ? "↑ 改善" : res_jp > prev_jp + 0.1 ? "↓ 恶化" : "→ 持平")
trend_eu = is_mode_A ? (res_eu > prev_eu + 0.1 ? "↑ 改善" : res_eu < prev_eu - 0.1 ? "↓ 恶化" : "→ 持平") : (res_eu < prev_eu - 0.1 ? "↑ 改善" : res_eu > prev_eu + 0.1 ? "↓ 恶化" : "→ 持平")

trend_col_us = trend_us == "↑ 改善" ? color.rgb(0,220,150) : trend_us == "↓ 恶化" ? color.rgb(255,60,60) : c_lightgray
trend_col_cn = trend_cn == "↑ 改善" ? color.rgb(0,220,150) : trend_cn == "↓ 恶化" ? color.rgb(255,60,60) : c_lightgray
trend_col_jp = trend_jp == "↑ 改善" ? color.rgb(0,220,150) : trend_jp == "↓ 恶化" ? color.rgb(255,60,60) : c_lightgray
trend_col_eu = trend_eu == "↑ 改善" ? color.rgb(0,220,150) : trend_eu == "↓ 恶化" ? color.rgb(255,60,60) : c_lightgray

// 动态全局评测（V26）
active_count      = (show_us ? 1 : 0) + (show_cn ? 1 : 0) + (show_jp ? 1 : 0) + (show_eu ? 1 : 0)
active_count_safe = active_count > 0 ? active_count : 1

avg_sev_raw  = (show_us ? float(sev_us) : 0.0) + (show_cn ? float(sev_cn) : 0.0) + (show_jp ? float(sev_jp) : 0.0) + (show_eu ? float(sev_eu) : 0.0)
avg_sev      = avg_sev_raw / float(active_count_safe)
avg_debt_raw = (show_us ? us_d : 0.0) + (show_cn ? cn_d : 0.0) + (show_jp ? jp_d : 0.0) + (show_eu ? eu_d : 0.0)
avg_debt     = avg_debt_raw / float(active_count_safe)

float urgent_thresh  = active_count <= 1 ? 4.0 : active_count == 2 ? 3.5 : 3.0
float warning_thresh = active_count <= 1 ? 3.0 : active_count == 2 ? 2.5 : 2.0

is_urgent  = avg_sev >= urgent_thresh  or avg_debt > 160
is_warning = not is_urgent and (avg_sev >= warning_thresh or avg_debt > 120)


// ==========================================
// 5. V2.3 单国深度数据（看板所需）
// ==========================================
// 欧盟2年期国债统一使用德国代理
y2_s    = (country == "中国" ? "TVC:CN02Y"         : country == "美国" ? "TVC:US02Y"         : country == "日本" ? "TVC:JP02Y"         : "TVC:DE02Y")
y10_s   = (country == "中国" ? "TVC:CN10Y"         : country == "美国" ? "TVC:US10Y"         : country == "日本" ? "TVC:JP10Y"         : "TVC:DE10Y")
m1_s    = (country == "中国" ? "ECONOMICS:CNM1"    : country == "美国" ? "ECONOMICS:USM1"    : country == "日本" ? "ECONOMICS:JPM1"    : "ECONOMICS:EUM1")
m2_s    = (country == "中国" ? "ECONOMICS:CNM2"    : country == "美国" ? "ECONOMICS:USM2"    : country == "日本" ? "ECONOMICS:JPM2"    : "ECONOMICS:EUM2")
cpi_sym = (country == "中国" ? "ECONOMICS:CNIRYY"  : country == "美国" ? "ECONOMICS:USIRYY"  : country == "日本" ? "ECONOMICS:JPIRYY"  : "ECONOMICS:EUIRYY")
ppi_sym = (country == "中国" ? "ECONOMICS:CNPPIYY" : country == "美国" ? "ECONOMICS:USPPIYY" : country == "日本" ? "ECONOMICS:JPPPIYY" : "ECONOMICS:EUPPIYY")

// 选定国家 Dalio 三变量
selected_debt = (country == "中国" ? f_get_macro("ECONOMICS:CNGDG")       :
                country == "美国"  ? f_get_macro("FRED:GFDEGDQ188S")      :
                country == "日本"  ? f_get_macro("ECONOMICS:JPGDG")        :
                f_get_macro("ECONOMICS:EUGDG"))

selected_yield = (country == "中国" ? f_get_macro("TVC:CN10Y")  :
                 country == "美国"  ? f_get_macro("TVC:US10Y")  :
                 country == "日本"  ? f_get_macro("TVC:JP10Y")  :
                 f_get_macro("TVC:DE10Y"))

selected_gdp = (country == "中国" ? f_get_macro("ECONOMICS:CNGDPYY")  :
               country == "美国"  ? f_get_macro("ECONOMICS:USGDPYY")  :
               country == "日本"  ? f_get_macro("ECONOMICS:JPGDPYY")  :
               f_get_macro("ECONOMICS:EUGDPYY"))

// 修复：全球流动性指标 - 使用固定时间跨度的锚点逻辑
global_dxy    = request.security(dxy_symbol,    "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
global_us_10y = request.security(us_10y_symbol, "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// 修复：全球流动性评估 - 使用固定锚点逻辑，避免周期错位
global_dxy_prev    = request.security(dxy_symbol,    "D", nz(close[63], close), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
global_us_10y_prev = request.security(us_10y_symbol, "D", nz(close[63], close), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

global_tightening = global_dxy > global_dxy_prev and global_us_10y > global_us_10y_prev
global_loosening  = global_dxy < global_dxy_prev and global_us_10y < global_us_10y_prev
global_risk_score = global_tightening ? 2 : global_loosening ? 0 : 1

// 选定国家 Dalio 指标
dalio_result   = f_calc_val(calc_mode, selected_debt, selected_yield, selected_gdp)
dalio_severity = f_severity(calc_mode, dalio_result, selected_debt)
total_pressure = selected_debt * ((selected_debt / 100) * selected_yield)

// 修复：债务增长率计算，避免除以零或NA
safe_prev_debt = nz(selected_debt[get_bars(12)], 1)
safe_curr_debt = nz(selected_debt, safe_prev_debt)
debt_growth    = safe_prev_debt != 0 ? (safe_curr_debt - safe_prev_debt) / safe_prev_debt * 100 : 0

// 修复：债务增速斜率计算 - 使用固定月份6.0，而非动态get_bars(6)
debt_growth_slope = (debt_growth - nz(debt_growth[get_bars(6)], debt_growth)) / 6.0

adjusted_severity = math.min(f_severity(calc_mode, dalio_result, selected_debt) + (debt_growth_slope > 1 ? 1 : 0), 4)

// M1/M2/利率月线数据
m1  = sec(m1_s,  close[1])
m2  = sec(m2_s,  close[1])
y10 = sec(y10_s, close[1])
y2  = sec(y2_s,  close[1])
credit_spread      = sec("FRED:BAMLH0A0HYM2", close[1])
credit_spread_prev = sec("FRED:BAMLH0A0HYM2", close[2])
rate_rank = sec(y2_s, calc_manual_rank(close[1], lookback_months))
rate_avg  = sec(y2_s, ta.sma(close[1], lookback_months))

m1_p  = sec(m1_s,  close[13])
m2_p  = sec(m2_s,  close[13])
m1_l  = sec(m1_s,  close[2])
m2_l  = sec(m2_s,  close[2])
y10_l = sec(y10_s, close[2])
y2_l  = sec(y2_s,  close[2])

cpi_yoy   = sec(cpi_sym, ta.sma(close[1], macro_sma_len))
ppi_yoy   = sec(ppi_sym, ta.sma(close[1], macro_sma_len))
cpi_yoy_p = sec(cpi_sym, ta.sma(close[2], macro_sma_len))
ppi_yoy_p = sec(ppi_sym, ta.sma(close[2], macro_sma_len))

hg_c = sec("COMEX:HG1!", close[1])
gc_c = sec("COMEX:GC1!", close[1])


// ==========================================
// 6. V2.3 核心指标计算
// ==========================================
// CPI和PPI动量计算，使用nz()处理NA值
cpi_mom = nz(cpi_yoy) - nz(cpi_yoy_p)
ppi_mom = nz(ppi_yoy) - nz(ppi_yoy_p)

raw_m1_yoy   = (nz(m1) - nz(m1_p)) / nz(m1_p, 1) * 100
raw_m2_yoy   = (nz(m2) - nz(m2_p)) / nz(m2_p, 1) * 100
raw_scissors = raw_m1_yoy - raw_m2_yoy

m1_yoy   = cap(raw_m1_yoy)
m2_yoy   = cap(raw_m2_yoy)
scissors = cap(raw_scissors)

scissors_mome = cap(ta.ema(raw_scissors, get_bars(6)))

cgr_ratio = nz(hg_c, 0) / nz(gc_c, 1)
cgr_ma    = ta.ema(cgr_ratio, get_bars(cgr_ma_len))
risk_on   = cgr_ratio > cgr_ma

term_spread       = y10 - y2
liquidity_premium = y10 - raw_m2_yoy

real_rate_ppi = y10 - ppi_yoy
real_rate_cpi = y10 - cpi_yoy
is_real_loose = real_rate_cpi < th_real_rate

m1_mom       = (nz(m1) - nz(m1_l)) / nz(m1_l, 1) * 100
m1_mom_ma    = ta.sma(m1_mom, get_bars(m1_mom_ma_len))
is_m1_turning_up = m1_mom_ma > nz(m1_mom_ma[1])

