indicator("债务经济数据分析（中远期）最终版2", shorttitle="债务经济数据分析（中远期）最终版2", overlay=false, max_lines_count=500, max_labels_count=500)

// ==========================================
// 1. 公共函数
// ==========================================

f_get_macro(_tic) =>
    _raw   = request.security(_tic, "D", close, gaps=barmerge.gaps_off, ignore_invalid_symbol=true, lookahead=barmerge.lookahead_off)
    _fixed = ta.valuewhen(not na(_raw), _raw, 0)
    _fixed

// 5级严重度评分 (0=优秀 ~ 4=危机) - 已集成平滑调节因子
f_severity(_mode, _val, _debt) =>
    float base = 0.0
    if _mode == "模式A：名义GDP增长率减去10年国债收益率，越高越好"
        if _val > 3.0
            base := 0.0
        else if _val > 1.0
            base := 1.0
        else if _val > 0.0
            base := 2.0
        else if _val > -2.0
            base := 3.0
        else
            base := 4.0
    else
        if _val < 1.5
            base := 0.0
        else if _val < 2.5
            base := 1.0
        else if _val < 3.5
            base := 2.0
        else if _val < 5.0
            base := 3.0
        else
            base := 4.0
    
    // 引入平滑调节因子：债务率每超过100%后的增长会线性增加风险权重
    float debt_amp = math.min(math.max(0.0, (_debt - 100.0) / 50.0), 2.0)
    math.min(base + debt_amp, 4.0)

// 5级状态文字
f_diag_text(_sev) =>
    _sev == 0 ? "强扩张 (0/4)" : _sev == 1 ? "健康 (1/4)" : _sev == 2 ? "中性 (2/4)" : _sev == 3 ? "压力 (3/4)" : "危机 (4/4)"

// 5级颜色
f_sev_col(_sev) =>
    _sev == 0 ? color.rgb(0, 220, 150) :
     _sev == 1 ? color.rgb(100, 220, 100) :
     _sev == 2 ? color.rgb(220, 220, 50) :
     _sev == 3 ? color.rgb(255, 150, 0) :
                 color.rgb(255, 60, 60)

// 总计利息压力颜色判定
f_tp_col(_val) =>
    _val > 1200 ? color.rgb(255, 60, 60) :
     _val > 800  ? color.rgb(255, 150, 0) :
     _val > 450  ? color.rgb(220, 220, 50) :
     _val > 150  ? color.rgb(100, 220, 100) :
                   color.rgb(0, 220, 150)

// Dalio综合视角
f_comp_diag(_debt, _mode, _sev) =>
    string s = ""
    if _mode == "模式A：名义GDP增长率减去10年国债收益率，越高越好"
        if _sev == 0
            s := "增长远超利率\n和谐去杠杆\n扩张潜力强"
        else if _sev == 1
            s := "温和正利差\n债务周期健康\n可持续增长"
        else if _sev == 2
            s := "利差趋近于零\n债务周期中性\n警惕利率上行"
        else if _sev == 3
            s := "利率反超增长\n去杠杆压力期\n需政策对冲"
        else
            s := "严重负利差\n债务危机风险\n需强力政策干预"
    else
        string dlv = _debt > 200 ? "极高>200%" : _debt > 150 ? "极高" : _debt > 130 ? "高" : _debt > 100 ? "中高" : "中等"
        if _sev == 0
            s := "债务" + dlv + "\n利息极轻\n长期可持续"
        else if _sev == 1
            s := "债务" + dlv + "\n利息轻度\n健康运行"
        else if _sev == 2
            s := "债务" + dlv + "\n利息中等\n需保持观察"
        else if _sev == 3
            s := "债务" + dlv + "\n利息偏重\n债务周期后期"
        else
            s := "债务" + dlv + "\n利息沉重\n流动性危机风险"
    s

// 归一化辅助函数
calc_manual_rank(src, len) =>
    float count_below = 0.0
    for i = 1 to len
        if not na(src[i]) and src[i] < src
            count_below += 1.0
    (count_below / len) * 100.0

f_normalize_percentile(src, len) =>
    calc_manual_rank(src, len) / 100.0

// 时间有效性检查
is_valid_time() =>
    not na(time) and year >= 2000

// 月K线辅助函数
get_bars(int months) =>
    int multiplier = timeframe.ismonthly ? 1 : timeframe.isweekly ? 4 : timeframe.isdaily ? 21 : 21
    months * multiplier

sec(sym, expr) => request.security(sym, "1M", expr, lookahead=barmerge.lookahead_off)

// 同比数值封顶
cap_val = input.float(40.0, "同比数值封顶", group="字体设置")

cap(v) => math.max(-cap_val, math.min(cap_val, v))


