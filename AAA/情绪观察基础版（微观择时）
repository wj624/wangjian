        matrixAction := "勿接飞刀 🚫"
        backtestSignal := -1
    else if isBearSync
        if isGmmaBearish
            matrixStatus := "主跌浪彻底确立"
            matrixColor  := color.rgb(255, 255, 255)
            matrixAction := "坚决空仓"
            backtestSignal := -1
        else
            matrixStatus := "高位破位杀跌"
            matrixColor  := color.rgb(255, 82, 82)
            matrixAction := "破位止损"
            backtestSignal := -1
    else if isVwHigh
        matrixStatus := "高位滞涨预警"
        matrixColor  := color.rgb(255, 100, 100) 
        matrixAction := "逐步减仓"
        backtestSignal := 0
    else
        if isGmmaBearish
            matrixStatus := "均线压制阴跌"
            matrixColor  := color.rgb(255, 255, 255)
            matrixAction := "反抽清仓"
            backtestSignal := 0
        else
            matrixStatus := "高位震荡博弈"
            matrixColor  := color.rgb(255, 255, 255) 
            matrixAction := "谨慎持仓"
            backtestSignal := 0

else if chipDistRatio < -chipThreshold
    if isBotDiverge
        if isAtrHigh 
            matrixStatus := "底部暴力洗盘"
            matrixColor  := color.rgb(255, 235, 59)
            matrixAction := "起爆在即 🚀"
            backtestSignal := 1
        else         
            matrixStatus := "底部暗中建仓"
            matrixColor  := color.rgb(255, 235, 59)
            matrixAction := "主力吸筹潜伏 💰"
            backtestSignal := 1
    else if isBearSync
        if isAtrHigh 
            matrixStatus := "恐慌性连环踩踏"
            matrixColor  := color.rgb(180, 0, 255) 
            matrixAction := "严禁接刀 🚫"
            backtestSignal := -1
        else
            matrixStatus := "宏观极限冰点"
            matrixColor  := color.rgb(67, 255, 130)
            matrixAction := "左侧分批摸底"
            backtestSignal := 0
    else if isTopDiverge
        matrixStatus := "底部缩量假涨"
        matrixColor  := color.rgb(180, 0, 255)
        matrixAction := "防二次探底"
        backtestSignal := -1
    else if isBullSync
        if isGmmaBearish
