    // 🚨 优先级 3：原版的灵魂！VW与MFI量价共振 (原汁原味捕捉启动点)
    else if isBullSync and close >= open  // 👈 加上阴阳线防呆锁：大阴线砸盘时，绝不许报多头突破！
        if isGmmaSqueeze and isAtrHigh
            matrixStatus := "均线开花突破", matrixColor := color.rgb(0, 255, 255), matrixAction := "变盘满仓干 🚀", backtestSignal := 1
        else
            matrixStatus := "强势向上突破", matrixColor := color.rgb(0, 255, 128), matrixAction := "右侧跟随做多", backtestSignal := 1
    // 💡 镜像修复：大阳线反弹时，绝不许乱报断头铡刀！
    else if isBearSync and close <= open
        if isGmmaSqueeze and isAtrHigh
            matrixStatus := "密集区断头铡", matrixColor := color.rgb(255, 0, 0), matrixAction := "长线破位逃命 🚨", backtestSignal := -1
        else if isAtrHigh 
            matrixStatus := "断头铡刀破位", matrixColor := color.rgb(255, 0, 0), matrixAction := "无条件逃命", backtestSignal := -1
        else
            matrixStatus := "弱势向下破位", matrixColor := color.rgb(255, 152, 0), matrixAction := "破位止损", backtestSignal := -1
            
    // 🚨 优先级 4：ADX 垃圾时间拦截器 (前三者都没发生时，接管中央裁判权，切断无序假信号)
    else if isChopZone
        if isSmartAccumulation
            matrixStatus := "箱体隐蔽吸筹", matrixColor := color.rgb(200, 255, 138), matrixAction := "潜伏 / 观望", backtestSignal := 1
        else if isSmartDistribution
            matrixStatus := "箱体隐蔽派发", matrixColor := color.rgb(255, 152, 0), matrixAction := "防范向下变盘", backtestSignal := -1
        else
            matrixStatus := "死水无序震荡", matrixColor := color.rgb(150, 150, 150), matrixAction := "极低胜率 勿动", backtestSignal := 0
    else
        matrixStatus := "中枢缠绕博弈", matrixColor := color.new(color.white, 0), matrixAction := "顺势 / 观望", backtestSignal := 0


