    // 💡 镜像修复：防止大反弹阳线乱报“破位杀跌”
    else if isBearSync and close <= open
        if isGmmaBearish
            matrixStatus := "主跌浪彻底确立", matrixColor := color.rgb(255, 255, 255), matrixAction := "坚决空仓", backtestSignal := -1
        else
            matrixStatus := "高位破位杀跌", matrixColor := color.rgb(255, 82, 82), matrixAction := "破位止损", backtestSignal := -1
    else if isVwHigh
        matrixStatus := "高位滞涨预警", matrixColor := color.rgb(255, 100, 100), matrixAction := "逐步减仓", backtestSignal := 0
    else
        if isGmmaBearish
            matrixStatus := "均线压制阴跌", matrixColor := color.rgb(255, 255, 255), matrixAction := "反抽清仓", backtestSignal := 0
        else
            matrixStatus := "高位震荡博弈", matrixColor := color.rgb(255, 255, 255), matrixAction := "谨慎持仓", backtestSignal := 0

else if chipDistRatio < -chipThreshold
