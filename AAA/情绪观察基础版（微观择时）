//@version=6
// 🧱 显式开启 TradingView 平台允许的 500 个标签最大物理上限
indicator(title="情绪观察", shorttitle="情绪观察", format=format.price, max_labels_count=500)

// ==================== 1. 基础输入参数 ====================
len = input.int(14, "RSI 周期", minval=1, group="1. RSI 参数设置")
src = input(close, "数据源", group="1. RSI 参数设置")
rsiOverbought = input.int(80, "RSI 超买阈值", group="1. RSI 参数设置")
rsiOversold   = input.int(20, "RSI 超卖阈值", group="1. RSI 参数设置")

macdFast = input.int(12, "MACD 快线", group="2. MACD(Hist) 设置")
macdSlow = input.int(26, "MACD 慢线", group="2. MACD(Hist) 设置")
macdSignal = input.int(9, "MACD 信号线", group="2. MACD(Hist) 设置")

plotMacdBull = input.bool(true, "常规底背离检测 (MACD柱)", group="2. MACD(Hist) 设置")
plotMacdHiddenBull = input.bool(true, "隐藏底背离检测 (MACD柱)", group="2. MACD(Hist) 设置") 
plotMacdBear = input.bool(true, "常规顶背离检测 (MAC柱)", group="2. MACD(Hist) 设置")
plotMacdHiddenBear = input.bool(true, "隐藏顶背离检测 (MACD柱)", group="2. MACD(Hist) 设置") 

lbR = input.int(3, "枢轴右视距", group="3. 枢轴结构测距设置")
lbL = input.int(3, "枢轴左视距", group="3. 枢轴结构测距设置")
rangeUpper = input.int(60, "最大回溯范围", group="3. 枢轴结构测距设置")
rangeLower = input.int(5, "最小回溯范围", group="3. 枢轴结构测距设置")

plotBull = input.bool(true, "常规底背离检测 (RSI)", group="4. RSI 显示设置")
plotHiddenBull = input.bool(true, "隐藏底背离检测 (RSI)", group="4. RSI 显示设置") 
plotBear = input.bool(true, "常规顶背离检测 (RSI)", group="4. RSI 显示设置")
plotHiddenBear = input.bool(true, "隐藏顶背离检测 (RSI)", group="4. RSI 显示设置") 

showAtr = input.bool(true, "显示 ATR 波动率", group="5. ATR 波动率设置")
atrLen = input.int(14, "ATR 周期", group="5. ATR 波动率设置")
atrLookback = input.int(100, "ATR 极值回溯", group="5. ATR 波动率设置")
atrMaxHeight = input.int(100, "柱状图高度", group="5. ATR 波动率设置") 

mfiLen = input.int(14, "MFI 周期", group="6. MFI 资金流共振")
syncWindow = input.int(3, "MFI容错窗口(K线数)", minval=1, maxval=30, group="6. MFI 资金流共振")
showMfiLine = input.bool(true, "【开关】显示 MFI 资金流原生折线", group="6. MFI 资金流共振")

cciLen = input.int(20, "CCI 周期", group="7. CCI 极端偏离刺探器")
cciExtremeOB = input.int(200, "CCI 极端超买警戒线", group="7. CCI 极端偏离刺探器")
cciExtremeOS = input.int(-200, "CCI 极端超卖警戒线", group="7. CCI 极端偏离刺探器")

showRealTime = input.bool(true, "【显示】实时显示指标", group="8. 视觉报警控制台")
showLagging  = input.bool(true, "【显示】滞后3K确认指标", group="8. 视觉报警控制台")
showBgAlert  = input.bool(true, "【显示】阶梯背景报警", group="8. 视觉报警控制台")
maxLabelCount = input.int(120, "每类标签历史留存数量", minval=10, maxval=150, group="8. 视觉报警控制台")

showAtrPanel = input.bool(true, "显示 ATR/均线/筹码 风控面板", group="9. 止损参考信息 (面板设置)")
atrPanelPosStr = input.string("右上角", "面板位置", options=["右上角", "左上角", "右下角", "左下角"], group="9. 止损参考信息 (面板设置)")
atrMult = input.float(2.0, "ATR 止损倍数 (1-4)", minval=1.0, maxval=4.0, step=0.5, group="9. 止损参考信息 (面板设置)")
maLen = input.int(60, "均线止损周期", minval=1, group="9. 止损参考信息 (面板设置)")
maType = input.string("EMA", "均线类型", options=["EMA", "SMA"], group="9. 止损参考信息 (面板设置)")

showVwKdj = input.bool(true, "【开关】显示 VW-KDJ 资金波段", group="10. VW-KDJ 资金波段 (附属模块)") 
vwLookback = input.int(36, "极值回溯周期 (N)", minval=1, group="10. VW-KDJ 资金波段 (附属模块)")
vwSmooth1  = input.int(3, "资金平滑 1", minval=1, group="10. VW-KDJ 资金波段")
vwSmooth2  = input.int(3, "资金平滑 2", minval=1, group="10. VW-KDJ 资金波段")
vwSmooth3  = input.int(3, "资金平滑 3", minval=1, group="10. VW-KDJ 资金波段")
vwObLevel = input.int(80, "超买警戒线", minval=50, maxval=100, group="10. VW-KDJ 资金波段")
vwOsLevel = input.int(20, "超卖警戒线", minval=0, maxval=50, group="10. VW-KDJ 资金波段")
vwUseVwmaSrc = input.bool(true, "源数据使用3日资金均价", group="10. VW-KDJ 资金波段")

showGmmaBand = input.bool(true, "【开关】显示中轴顾比带", group="11. 顾比均线中轴参数")
gmmaSrc = input(close, "顾比均线数据源", group="11. 顾比均线中轴参数")
entangleThreshold = input.int(28, "震荡区强行捕获阈值", group="11. 顾比均线中轴参数")

useVolFilter = input.bool(true, "【方案一】启用量能与右侧过滤", group="12. 终极升级方案核心配置")
volMultInput = input.float(1.2, "恐慌盘成交量均线倍数", minval=1.0, step=0.1, group="12. 终极升级方案核心配置")

showPctLines = input.bool(true, "【方案二】显示 RSI 生命周期", group="12. 终极升级方案核心配置")
showMfiPctLines = input.bool(true, "【方案二】显示 MFI 生命周期", group="12. 终极升级方案核心配置")
pctLen       = input.int(100, "分位数通道回溯周期", minval=20, group="12. 终极升级方案核心配置")

pctColorUp   = input.color(#ff00aa, "RSI 超买线颜色", group="12.1 自适应通道控制")
pctTransUp   = input.int(40, "RSI 超买线透明度", minval=0, maxval=100, group="12.1 自适应通道控制")
pctColorDn   = input.color(#00ffaa, "RSI 超卖线颜色", group="12.1 自适应通道控制")
pctTransDn   = input.int(40, "RSI 超卖线透明度", minval=0, maxval=100, group="12.1 自适应通道控制")
pctFillColor = input.color(#9c27b0, "RSI 内部填充颜色", group="12.1 自适应通道控制")
pctFillTrans = input.int(70, "RSI 内部填充透明度", minval=0, maxval=100, group="12.1 自适应通道控制")

mfiPctColorUp  = input.color(#ff9800, "MFI 超买线颜色", group="12.2 MFI通道控制")
mfiPctTransUp   = input.int(40, "MFI 超买线透明度", minval=0, maxval=100, group="12.2 MFI通道控制")
mfiPctColorDn   = input.color(#e0a800, "MFI 超卖线颜色", group="12.2 MFI通道控制")
mfiPctTransDn   = input.int(40, "MFI 超卖线透明度", minval=0, maxval=100, group="12.2 MFI通道控制")
mfiPctFillColor = input.color(#008cff, "MFI 内部填充颜色", group="12.2 MFI通道控制")
mfiPctFillTrans = input.int(60, "MFI 内部填充透明度", minval=0, maxval=100, group="12.2 MFI通道控制")

// ==================== 13. 长周期筹码与意图雷达 ====================
chipLen = input.int(200, "筹码监控周期 (日)", group="13. 筹码与主力意图")
extremeMult = input.float(2.0, "极限偏离倍数", group="13. 筹码与主力意图")
thresholdMult = input.float(1.0, "常规偏离倍数", group="13. 筹码与主力意图")
neutralMult = input.float(0.4, "中枢缠绕倍数", group="13. 筹码与主力意图")

// ==================== 14. 5D雷达高级微调 ====================
grp5d = "14. 5D雷达高级微调"
diffThreshold  = input.float(30.0, "背离差值警戒线", group=grp5d)
vwHighLvl      = input.int(70, "VW 超买绝对阈值", group=grp5d)
vwLowLvl       = input.int(30, "VW 超卖绝对阈值", group=grp5d)
mfiBullSyncLvl = input.int(65, "MFI 多头及格阈值", group=grp5d)
mfiBearSyncLvl = input.int(35, "MFI 空头及格阈值", group=grp5d)
squeezeMinBars = input.int(5, "均线密集需连续确认的K线数", group=grp5d)
atrSqueezeMax  = input.int(40, "均线密集期最大ATR均值", group=grp5d)

// ==================== 🌟 15. 小波段动态核算 ====================
grpVW = "15. 小波段动态核算 (VW盈亏比)"
vwTargetLevel = input.int(80, "VW 预测目标数值 (默认80)", minval=10, maxval=150, step=5, tooltip="填 80 表示推算未来 VW 波段指标打到 80 时，对应的绝对目标价格。", group=grpVW)
minProfitPct = input.float(5.0, "最小预期利润 (%)", group=grpVW)
minRrr       = input.float(1.5, "最低可接受盈亏比", group=grpVW)

// ==================== 🛡️ 16. 震荡与真假突破过滤引擎 ====================
grpChop = "16. 震荡与真假突破过滤引擎"
adxLen = input.int(14, "ADX 周期", group=grpChop)
adxChopLevel = input.int(20, "ADX 死水阈值 (低于此值面板锁死)", group=grpChop)
adxTrendLevel = input.int(25, "ADX 趋势阈值 (高于此值视为真趋势)", group=grpChop)
boxLen = input.int(20, "局部箱体判定周期 (唐奇安通道)", minval=5, maxval=60, group=grpChop)
slopeLen = input.int(10, "资金斜率探测周期 (天数)", minval=3, maxval=20, group=grpChop)

// ==================== 核心颜色定义 ====================
bearColor = color.red
bullColor = color.green
textColor = color.white
extremeWarnColor = color.fuchsia
mfiColor = color.new(#FF9800, 0)

// ==================== [ 第一阶段：底层引擎计算 ] ====================
vwSafeVol = na(volume) or volume == 0 ? 1 : volume
osc = ta.rsi(src, len)

tp = hlc3
rawMoneyFlow = tp * vwSafeVol
posFlow = tp > tp[1] ? rawMoneyFlow : 0.0
negFlow = tp < tp[1] ? rawMoneyFlow : 0.0
sumPosFlow = math.sum(posFlow, mfiLen)
sumNegFlow = math.sum(negFlow, mfiLen)
safeNegFlow = sumNegFlow == 0 ? 0.000001 : sumNegFlow
mfiVal = 100 - (100 / (1 + (sumPosFlow / safeNegFlow)))

[_, _, macdHist] = ta.macd(src, macdFast, macdSlow, macdSignal)
closeCci = ta.cci(hlc3, cciLen)

atr = ta.atr(atrLen)
atrMax = ta.highest(atr, atrLookback)
atrMin = ta.lowest(atr, atrLookback)
atrPercent = (atr - atrMin) / math.max(atrMax - atrMin, 0.000001) * 100
normalizedAtr = (atrPercent / 100) * atrMaxHeight
atrColor = atrPercent >= 80 ? color.new(color.orange, 60) : atrPercent <= 20 ? color.new(color.green, 60) : color.new(#787B86, 80)

maEma = ta.ema(close, maLen)
maSma = ta.sma(close, maLen)
maVal = maType == "EMA" ? maEma : maSma
maDist = close - maVal
maRatio = (maDist / math.max(close, 1e-10)) * 100

// 🎯 筹码重心算法
chipGravityLine = math.sum(vwSafeVol * hlc3, chipLen) / math.max(math.sum(vwSafeVol, chipLen), 1e-10)
chipDistRatio = (close - chipGravityLine) / chipGravityLine * 100

// 🧬 自适应标准差
chipStdDev = ta.stdev(chipDistRatio, chipLen)
safeChipStdDev = math.max(nz(chipStdDev, 1.0), 1.0) 

chipThreshold = safeChipStdDev * thresholdMult
chipExtreme = safeChipStdDev * extremeMult
atrBasePct = (atr / close) * 100  
chipNeutral = math.max(safeChipStdDev * neutralMult, atrBasePct * 0.1)

string volMod = atrPercent >= 80 ? " (剧烈)" : atrPercent <= 20 ? " (极静)" : " (稳健)"
string baseChipStatus = ""
string actionSignal = ""
color chipStatusColor = color.white

if chipDistRatio > chipExtreme
    baseChipStatus := "情绪泡沫", actionSignal := " (空)", chipStatusColor := color.rgb(255, 0, 0)
else if chipDistRatio > chipThreshold
    baseChipStatus := "良性洗盘", actionSignal := " (多)", chipStatusColor := color.rgb(0, 255, 128)
else if chipDistRatio > chipNeutral
    baseChipStatus := "中枢偏强", actionSignal := " (等/多)", chipStatusColor := color.rgb(255, 152, 0)
else if chipDistRatio >= -chipNeutral
    baseChipStatus := "中枢震荡", actionSignal := " (等)", chipStatusColor := color.rgb(255, 255, 255)
else if chipDistRatio > -chipThreshold
    baseChipStatus := "中枢偏弱", actionSignal := " (等/空)", chipStatusColor := color.rgb(153, 204, 255)
else if chipDistRatio >= -chipExtreme
    baseChipStatus := "底部吸筹", actionSignal := " (多)", chipStatusColor := color.rgb(255, 235, 59)
else
    baseChipStatus := "极限错杀", actionSignal := " (多)", chipStatusColor := color.rgb(0, 213, 255)

string chipStatus = baseChipStatus + volMod + actionSignal

volMa = ta.sma(vwSafeVol, 20)
volClimax = vwSafeVol > volMa * volMultInput
priceConfirm = close > ta.ema(close, 9)
anyVolClimaxRecently = math.sum(volClimax ? 1 : 0, lbR + 1) > 0
bullFilterPassed = not useVolFilter or (anyVolClimaxRecently or priceConfirm)

rsiPctUpper = ta.percentile_linear_interpolation(osc, pctLen, 80)
rsiPctLower = ta.percentile_linear_interpolation(osc, pctLen, 20)
mfiPctUpper = ta.percentile_linear_interpolation(mfiVal, pctLen, 80)
mfiPctLower = ta.percentile_linear_interpolation(mfiVal, pctLen, 20)

// ==================== 顾比均线核心 ====================
gS1 = ta.ema(gmmaSrc, 3), gS2 = ta.ema(gmmaSrc, 5), gS3 = ta.ema(gmmaSrc, 8), gS4 = ta.ema(gmmaSrc, 10), gS5 = ta.ema(gmmaSrc, 12), gS6 = ta.ema(gmmaSrc, 15)
gL1 = ta.ema(gmmaSrc, 30), gL2 = ta.ema(gmmaSrc, 35), gL3 = ta.ema(gmmaSrc, 40), gL4 = ta.ema(gmmaSrc, 45), gL5 = ta.ema(gmmaSrc, 50), gL6 = ta.ema(gmmaSrc, 60)

crossScore = 0
crossScore := crossScore + (gS1 > gL1 ? 1 : -1) + (gS1 > gL2 ? 1 : -1) + (gS1 > gL3 ? 1 : -1) + (gS1 > gL4 ? 1 : -1) + (gS1 > gL5 ? 1 : -1) + (gS1 > gL6 ? 1 : -1)
crossScore := crossScore + (gS2 > gL1 ? 1 : -1) + (gS2 > gL2 ? 1 : -1) + (gS2 > gL3 ? 1 : -1) + (gS2 > gL4 ? 1 : -1) + (gS2 > gL5 ? 1 : -1) + (gS2 > gL6 ? 1 : -1)
crossScore := crossScore + (gS3 > gL1 ? 1 : -1) + (gS3 > gL2 ? 1 : -1) + (gS3 > gL3 ? 1 : -1) + (gS3 > gL4 ? 1 : -1) + (gS3 > gL5 ? 1 : -1) + (gS3 > gL6 ? 1 : -1)
crossScore := crossScore + (gS4 > gL1 ? 1 : -1) + (gS4 > gL2 ? 1 : -1) + (gS4 > gL3 ? 1 : -1) + (gS4 > gL4 ? 1 : -1) + (gS4 > gL5 ? 1 : -1) + (gS4 > gL6 ? 1 : -1)
crossScore := crossScore + (gS5 > gL1 ? 1 : -1) + (gS5 > gL2 ? 1 : -1) + (gS5 > gL3 ? 1 : -1) + (gS5 > gL4 ? 1 : -1) + (gS5 > gL5 ? 1 : -1) + (gS5 > gL6 ? 1 : -1)
crossScore := crossScore + (gS6 > gL1 ? 1 : -1) + (gS6 > gL2 ? 1 : -1) + (gS6 > gL3 ? 1 : -1) + (gS6 > gL4 ? 1 : -1) + (gS6 > gL5 ? 1 : -1) + (gS6 > gL6 ? 1 : -1)

shortOrder = (gS1 > gS2 ? 1 : -1) + (gS2 > gS3 ? 1 : -1) + (gS3 > gS4 ? 1 : -1) + (gS4 > gS5 ? 1 : -1) + (gS5 > gS6 ? 1 : -1)
longOrder  = (gL1 > gL2 ? 1 : -1) + (gL2 > gL3 ? 1 : -1) + (gL3 > gL4 ? 1 : -1) + (gL4 > gL5 ? 1 : -1) + (gL5 > gL6 ? 1 : -1)

gmmaNetScore = crossScore + shortOrder + longOrder
longMax = math.max(gL1, math.max(gL2, math.max(gL3, math.max(gL4, math.max(gL5, gL6)))))
longMin = math.min(gL1, math.min(gL2, math.min(gL3, math.min(gL4, math.min(gL5, gL6)))))
longWidth = longMax - longMin
avgLongWidth = ta.sma(longWidth, 100)
isLongContracted = longWidth < (avgLongWidth * 0.6)

color dynamicGmmaColor = na
if math.abs(gmmaNetScore) <= entangleThreshold or isLongContracted
    yellowRatio = (gmmaNetScore + entangleThreshold) / (entangleThreshold * 2)
    dynamicGmmaColor := color.from_gradient(yellowRatio * 100, 0, 100, color.new(#ffaa00, 30), color.new(#bbff00, 48))
else
    if gmmaNetScore > 0
        bullRatio = (gmmaNetScore - entangleThreshold) / (46 - entangleThreshold)
        dynamicGmmaColor := color.from_gradient(bullRatio * 100, 0, 100, color.new(#80c904, 35), color.new(#00bd0d, 15))
    else
        bearRatio = (math.abs(gmmaNetScore) - entangleThreshold) / (46 - entangleThreshold)
        dynamicGmmaColor := color.from_gradient(bearRatio * 100, 0, 100, color.new(#ff6a00, 35), color.new(#ff1100, 15))

// ==================== VW-KDJ 核心 ====================
vwCurrentVolat = high - low
vwAvgVolat = ta.sma(vwCurrentVolat, 20)
vwVolatWeight = vwCurrentVolat / math.max(vwAvgVolat, 1e-10)
vwVolatWeight := math.min(vwVolatWeight, 2.0)
vwSmartVolume = vwSafeVol * vwVolatWeight

custom_vwma(src_val, length) => math.sum(src_val * vwSmartVolume, length) / math.max(math.sum(vwSmartVolume, length), 1e-10)

vwma3 = custom_vwma(close, 3)
vwSrc = vwUseVwmaSrc ? vwma3 : close

// 🌟 VW 历史最高最低点
vwHh = ta.highest(high, vwLookback)
vwLl = ta.lowest(low, vwLookback)
vwRsv = (vwSrc - vwLl) / math.max(vwHh - vwLl, 1e-10) * 100

vwVar2 = custom_vwma(vwRsv, vwSmooth1)
vwVar3 = custom_vwma(vwVar2, vwSmooth2)  
vwVar4 = custom_vwma(vwVar3, vwSmooth3)  

vwKdjCrossOver  = ta.crossover(vwVar3, vwVar4)
vwKdjCrossUnder = ta.crossunder(vwVar3, vwVar4)
vwBuyCond = vwKdjCrossOver and vwVar3[1] < vwOsLevel and not na(vwVar3) and not na(vwVar4)
vwSellCond = vwKdjCrossUnder and vwVar3[1] > vwObLevel and not na(vwVar3) and not na(vwVar4)

// ==================== 🛠️ 防弹枢轴 ====================
plFound = not na(ta.pivotlow(osc, lbL, lbR)), phFound = not na(ta.pivothigh(osc, lbL, lbR))
macdPlFound = not na(ta.pivotlow(macdHist, lbL, lbR)), macdPhFound = not na(ta.pivothigh(macdHist, lbL, lbR))
mfiPlFound = not na(ta.pivotlow(mfiVal, lbL, lbR)), mfiPhFound = not na(ta.pivothigh(mfiVal, lbL, lbR))

prev_plBar    = ta.valuewhen(plFound, bar_index, 1), prev_phBar    = ta.valuewhen(phFound, bar_index, 1)
prev_mfiPlBar = ta.valuewhen(mfiPlFound, bar_index, 1), prev_mfiPhBar = ta.valuewhen(mfiPhFound, bar_index, 1)

inRangePl    = (bar_index - prev_plBar) >= rangeLower and (bar_index - prev_plBar) <= rangeUpper
inRangePh    = (bar_index - prev_phBar) >= rangeLower and (bar_index - prev_phBar) <= rangeUpper
inRangeMfiPl = (bar_index - prev_mfiPlBar) >= rangeLower and (bar_index - prev_mfiPlBar) <= rangeUpper
inRangeMfiPh = (bar_index - prev_mfiPhBar) >= rangeLower and (bar_index - prev_mfiPhBar) <= rangeUpper

history_mfiPl_low  = ta.valuewhen(mfiPlFound, low[lbR], 1), history_mfiPl_mfi  = ta.valuewhen(mfiPlFound, mfiVal[lbR], 1)
history_mfiPh_high = ta.valuewhen(mfiPhFound, high[lbR], 1), history_mfiPh_mfi  = ta.valuewhen(mfiPhFound, mfiVal[lbR], 1)

history_rsiPl_low  = ta.valuewhen(plFound, low[lbR], 1), history_rsiPl_osc  = ta.valuewhen(plFound, osc[lbR], 1)
history_rsiPh_high = ta.valuewhen(phFound, high[lbR], 1), history_rsiPh_osc  = ta.valuewhen(phFound, osc[lbR], 1)

// ==================== 核心背离计算 ====================
rsiBullAlert = plFound and inRangePl and low[lbR] < history_rsiPl_low and osc[lbR] > history_rsiPl_osc
rsiBearAlert = phFound and inRangePh and high[lbR] > history_rsiPh_high and osc[lbR] < history_rsiPh_osc
rsiHidBullAlert = plFound and inRangePl and low[lbR] > history_rsiPl_low and osc[lbR] < history_rsiPl_osc
rsiHidBearAlert = phFound and inRangePh and high[lbR] < history_rsiPh_high and osc[lbR] > history_rsiPh_osc

mfiBullAlert = mfiPlFound and inRangeMfiPl and low[lbR] < history_mfiPl_low and mfiVal[lbR] > history_mfiPl_mfi
mfiBearAlert = mfiPhFound and inRangeMfiPh and high[lbR] > history_mfiPh_high and mfiVal[lbR] < history_mfiPh_mfi
mfiHidBullAlert = mfiPlFound and inRangeMfiPl and low[lbR] > history_mfiPl_low and mfiVal[lbR] < history_mfiPl_mfi
mfiHidBearAlert = mfiPhFound and inRangeMfiPh and high[lbR] < history_mfiPh_high and mfiVal[lbR] > history_mfiPh_mfi

macdTurnUp = macdHist > macdHist[1] and macdHist[1] < macdHist[2]
macdTurnDown = macdHist < macdHist[1] and macdHist[1] > macdHist[2]

prevMacdPlLow = ta.valuewhen(macdPlFound, low[lbR], 0), prevMacdPlHist = ta.valuewhen(macdPlFound, macdHist[lbR], 0)
prevMacdPhHigh = ta.valuewhen(macdPhFound, high[lbR], 0), prevMacdPhHist = ta.valuewhen(macdPhFound, macdHist[lbR], 0)

distMacdPlAgg = ta.barssince(macdPlFound) + lbR, inRangeMacdPlAgg = rangeLower <= distMacdPlAgg and distMacdPlAgg <= rangeUpper
distMacdPhAgg = ta.barssince(macdPhFound) + lbR, inRangeMacdPhAgg = rangeLower <= distMacdPhAgg and distMacdPhAgg <= rangeUpper

macdBullAlert = macdTurnUp and low < prevMacdPlLow and macdHist > prevMacdPlHist and inRangeMacdPlAgg and macdHist < 0
macdBearAlert = macdTurnDown and high > prevMacdPhHigh and macdHist < prevMacdPhHist and inRangeMacdPhAgg and macdHist > 0
macdHidBullAlert = macdTurnUp and low > prevMacdPlLow and macdHist < prevMacdPlHist and inRangeMacdPlAgg and macdHist < 0
macdHidBearAlert = macdTurnDown and high < prevMacdPhHigh and macdHist > prevMacdPhHist and inRangeMacdPhAgg and macdHist > 0

mfiBullCount    = math.sum(mfiBullAlert ? 1 : 0, syncWindow + 1), mfiBearCount    = math.sum(mfiBearAlert ? 1 : 0, syncWindow + 1)
mfiHidBullCount = math.sum(mfiHidBullAlert ? 1 : 0, syncWindow + 1), mfiHidBearCount = math.sum(mfiHidBearAlert ? 1 : 0, syncWindow + 1)

isMfiBullSync    = mfiBullCount > 0 or mfiBullCount[lbR] > 0
isMfiBearSync    = mfiBearCount > 0 or mfiBearCount[lbR] > 0
isMfiHidBullSync = mfiHidBullCount > 0 or mfiHidBullCount[lbR] > 0
isMfiHidBearSync = mfiHidBearCount > 0 or mfiHidBearCount[lbR] > 0

mfiPureBull = mfiBullAlert and not rsiBullAlert and not macdBullAlert
mfiPureBear = mfiBearAlert and not rsiBearAlert and not macdBearAlert
mfiObCross = ta.crossover(mfiVal, 80), mfiOsCross = ta.crossunder(mfiVal, 20)

climaxCloudBull = osc < rsiPctLower and mfiVal < mfiPctLower and bullFilterPassed
climaxCloudBear = osc > rsiPctUpper and mfiVal > mfiPctUpper

// ====== 🛡️ 震荡与真假突破过滤引擎 ======
[diPlus, diMinus, adxValue] = ta.dmi(adxLen, adxLen)
isChopZone = adxValue < adxChopLevel
isTrendActive = adxValue >= adxTrendLevel

// 💡 修复盲区：加上阳线/阴线确认，绝不被"高开低走"或"低开高走"骗炮！
localHh = ta.highest(high[1], boxLen)
localLl = ta.lowest(low[1], boxLen)
isTrueBreakoutUp = close > localHh and (not useVolFilter or volClimax) and close >= open
isTrueBreakdown = close < localLl and (not useVolFilter or volClimax) and close <= open

mfiSlope = ta.linreg(mfiVal, slopeLen, 0) - ta.linreg(mfiVal, slopeLen, 5)
histAtrAvg = ta.sma(nz(atrPercent, 50), 20)
squeezeDuration = nz(ta.barssince(not isLongContracted), 0)
isGmmaSqueeze = isLongContracted and (squeezeDuration >= squeezeMinBars) and (histAtrAvg <= atrSqueezeMax)

isSmartAccumulation = isGmmaSqueeze and mfiSlope > 0 and mfiVal > 50
isSmartDistribution = isGmmaSqueeze and mfiSlope < 0 and mfiVal < 50
// ==========================================
// 🌟 核心附加模块：50日自适应成交量异动 (Z-Score) 🌟
// ==========================================
vol_length = 50
vol_mean = ta.sma(vwSafeVol, vol_length)
vol_std  = ta.stdev(vwSafeVol, vol_length)
vol_z_score = vol_std > 0 ? (vwSafeVol - vol_mean) / vol_std : 0

// 1. 定义量能引信
