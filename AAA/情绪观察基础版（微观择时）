bool isVwLow       = safeVw <= vwLowLvl
bool isAtrHigh     = safeAtr >= 80    
bool isAtrLow      = safeAtr <= 20    

bool isTopDiverge  = isVwHigh and (safeVw - safeMfi) > diffThreshold 
bool isBotDiverge  = isVwLow  and (safeMfi - safeVw) > diffThreshold 
bool isBullSync    = isVwHigh and safeMfi >= mfiBullSyncLvl 
bool isBearSync    = isVwLow  and safeMfi <= mfiBearSyncLvl 

// 3. GMMA 降维特征植入
bool isGmmaBullish = gmmaNetScore >= 30  
bool isGmmaBearish = gmmaNetScore <= -30 

// 🧬 神级升级 2：Squeeze 时间锁 (🌟 告别硬编码，接入动态参数)
float histAtrAvg = ta.sma(safeAtr, 20) 
int squeezeDuration = nz(ta.barssince(not isLongContracted), 0)

// 真正的横盘密集 = 均线粘合 + 这种粘合已经连续维持了足够久 + 过去波动率极低
bool isGmmaSqueeze = isLongContracted and (squeezeDuration >= squeezeMinBars) and (histAtrAvg <= atrSqueezeMax)

// ==================== 5D 状态机路由 ====================
if chipDistRatio > chipThreshold
    if isTopDiverge
        matrixStatus := "高位无量诱多"
        matrixColor  := color.rgb(255, 60, 200) 
        matrixAction := "顶背离逃命 🚨"
        backtestSignal := -1
