    // --- 2. 🌟 小波段 VW 动态核算计算 🌟 ---
    float targetPrice = vwLl + (vwHh - vwLl) * (vwTargetLevel / 100.0) 
    float stopPrice   = vwLl                         
    float reward      = targetPrice - close
    float risk        = close - stopPrice
    float safeRisk    = math.max(risk, 0.001)        
    float rrr         = reward > 0 ? (reward / safeRisk) : 0.0
    float rewardPct   = (reward / close) * 100
    
    string rrrEvalStr = ""
    color  rrrColor   = color.white
    
    if reward <= 0
        rrrEvalStr := "已达目标位"
        rrrColor   := color.new(color.gray, 0)
    else if rewardPct < minProfitPct
        rrrEvalStr := "肉小放弃"
        rrrColor   := color.rgb(255, 82, 82)
    else if rrr < minRrr
        rrrEvalStr := "风险失衡"
        rrrColor   := color.rgb(255, 152, 0)
    else
        rrrEvalStr := "盈亏比优"
        rrrColor   := color.rgb(0, 255, 128)
        
    string tgtStr    = str.tostring(targetPrice, "#.####")
    string tgtPctStr = (rewardPct > 0 ? "+" : "") + str.tostring(rewardPct, "#.##") + "%"
    string stpStr    = str.tostring(stopPrice, "#.####")
    string rrrValStr = "盈亏比: " + str.tostring(rrr, "#.##")
    
    // --- 3. 🌟 T0-T3 统帅层级一票否决鉴定 🌟 ---
    string finalTLevel = "", color finalTColor = na, string ultimateAction = ""
    
    bool isT0 = str.contains(matrixAction, "逃命") or str.contains(matrixAction, "雪崩") or str.contains(matrixAction, "崩盘") or str.contains(matrixAction, "坚决空仓") or str.contains(matrixAction, "破位止损") or str.contains(matrixAction, "严禁接刀") or str.contains(matrixAction, "重仓追入") or str.contains(matrixAction, "满仓干")  or str.contains(matrixAction, "起爆在即")
    
    bool isT1 = (topScore >= 2) or (botScore >= 2 and bullFilterPassed) or (showVwKdj and (vwBuyCond or vwSellCond)) or str.contains(matrixAction, "减仓") or str.contains(matrixAction, "减磅") or str.contains(matrixAction, "清仓") or str.contains(matrixAction, "防二次探底") or str.contains(matrixAction, "勿接飞刀") or str.contains(matrixAction, "防范")
    
    // 💡 修复盲区：加入"建仓"关键词，确保底部建仓能触发盈亏比风控核算
    bool isT2 = str.contains(matrixAction, "谨慎持仓") or str.contains(matrixAction, "左侧分批摸底") or str.contains(matrixAction, "吸筹")  or str.contains(matrixAction, "跟随做多") or str.contains(matrixAction, "快进快出") or str.contains(matrixAction, "防守型持有") or str.contains(matrixAction, "吸纳") or str.contains(matrixAction, "潜伏") or str.contains(matrixAction, "建仓")
    
    if isT0
        finalTLevel := "T0 统帅", finalTColor := backtestSignal == 1 ? color.rgb(0, 255, 128) : color.rgb(255, 50, 50)
        string prefixT0 = backtestSignal == 1 ? "[最高指令] " : "[一票否决] "
        ultimateAction := prefixT0 + matrixAction
    else if isT1
        finalTLevel := "T1 警戒", finalTColor := color.rgb(255, 152, 0)
        // 💡 修复盲区：保留底层具体战术动作，拒绝 T1 一刀切的"失忆症"
        ultimateAction := "[极值警戒] " + (matrixAction == "" ? "设硬风控" : matrixAction)
    else if isT2
        finalTLevel := "T2 风控", finalTColor := color.rgb(0, 213, 255)
        // 💡 修复盲区：同步在盈亏比计算中加入"建仓"
        if (backtestSignal == 1 or str.contains(matrixAction, "吸纳") or str.contains(matrixAction, "摸底") or str.contains(matrixAction, "潜伏") or str.contains(matrixAction, "建仓")) and (rewardPct < minProfitPct or rrr < minRrr) and (reward > 0)
            ultimateAction := "[放弃] " + rrrEvalStr, finalTColor := rrrColor
        else
            ultimateAction := "[T2] " + matrixAction
    else
        finalTLevel := "T3 前哨", finalTColor := color.rgb(200, 200, 200)
        if (rewardPct < minProfitPct or rrr < minRrr) and (reward > 0)
            ultimateAction := "[观望] " + rrrEvalStr
        else
            ultimateAction := "[T3] " + matrixAction

    // --- 4. 渲染面板表格 ---
    table.cell(atrTable, 0, 0, "实时 ATR", text_color=color.white, text_size=size.small, text_halign=text.align_left)
