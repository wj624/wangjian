if showAtrPanel and barstate.islast
    // --- 1. 常规硬风控计算 ---
    atrStopDist = atr * atrMult, atrBaseRatio = (atr / close) * 100, atrRatio = (atrStopDist / close) * 100
    baseStr = str.tostring(atr, "#.####") + " (" + str.tostring(atrBaseRatio, "#.##") + "%)"
    targetStr = str.tostring(atrStopDist, "#.####") + " (" + str.tostring(atrRatio, "#.##") + "%)"
    maPriceStr = str.tostring(maVal, "#.####")
    maDiffStr = str.tostring(maDist, "#.####") + " (" + str.tostring(maRatio, "#.##") + "%)"
