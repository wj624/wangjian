    table.cell(atrTable, 1, 3, tgtStr, text_color=color.rgb(255, 100, 200), text_size=size.small, text_halign=text.align_center)
    table.cell(atrTable, 2, 3, tgtPctStr, text_color=color.rgb(255, 100, 200), text_size=size.small, text_halign=text.align_right)

    table.cell(atrTable, 0, 4, "VW 波段底线 (止损)", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(atrTable, 1, 4, stpStr, text_color=color.rgb(255, 82, 82), text_size=size.small, text_halign=text.align_center)
    table.cell(atrTable, 2, 4, rrrEvalStr + (reward > 0 ? " (" + rrrValStr + ")" : ""), text_color=rrrColor, text_size=size.small, text_halign=text.align_right)

    chipPriceStr = str.tostring(chipGravityLine, "#.####"), chipCombinedStr = str.tostring(chipDistRatio, "#.##") + "% [" + chipStatus + "]"
    table.cell(atrTable, 0, 5, "200日筹码状态", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(atrTable, 1, 5, chipPriceStr, text_color=color.rgb(255, 152, 0), text_size=size.small, text_halign=text.align_center)
    table.cell(atrTable, 2, 5, chipCombinedStr, text_color=chipStatusColor, text_size=size.small, text_halign=text.align_right)

    table.cell(atrTable, 0, 6, finalTLevel, text_color=finalTColor, text_size=size.small, text_halign=text.align_left)
    table.cell(atrTable, 1, 6, matrixStatus, text_color=matrixColor, text_size=size.small, text_halign=text.align_center)
    table.cell(atrTable, 2, 6, ultimateAction, text_color=finalTColor, text_size=size.small, text_halign=text.align_right)


